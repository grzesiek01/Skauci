---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Gromada wilczków" } = Astro.props;
const { user } = Astro.locals;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title} — Gromada wilczków</title>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900">
    <header class="border-b border-gray-200 bg-white shadow-sm">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
        <a href="/wilczki" class="text-lg font-bold text-green-700 hover:text-green-800"> 🐺 Gromada wilczków </a>
        <nav class="flex items-center gap-6 text-sm">
          <a href="/wilczki" class="text-gray-600 hover:text-gray-900">Wilczki</a>
          <a href="/zbiorki" class="text-gray-600 hover:text-gray-900">Zbiórki</a>
          <a href="/skladki" class="text-gray-600 hover:text-gray-900">Składki</a>
          <a href="/sprawnosci" class="text-gray-600 hover:text-gray-900">Sprawności</a>
          <span class="text-gray-400">|</span>
          <span class="text-gray-500">{user?.email}</span>
          <form method="POST" action="/api/auth/signout">
            <button
              type="submit"
              class="rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm text-gray-600 transition-colors hover:bg-gray-50 hover:text-gray-900"
            >
              Wyloguj
            </button>
          </form>
        </nav>
      </div>
    </header>
    <main class="mx-auto max-w-6xl px-4 py-8">
      <slot />
    </main>
  </body>
</html>
