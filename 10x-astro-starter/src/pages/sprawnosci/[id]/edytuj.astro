---
import AppLayout from "@/layouts/AppLayout.astro";
import SprawnosccForm from "@/components/sprawnosci/SprawnosccForm";
import { createClient } from "@/lib/supabase";
import type { Sprawnosc } from "@/types";

const { id } = Astro.params;
const supabase = createClient(Astro.request.headers, Astro.cookies);
if (!supabase) return Astro.redirect("/auth/signin");

const { data: sprawnosc, error } = await supabase.from("sprawnosci").select("*").eq("id", id).single<Sprawnosc>();

// eslint-disable-next-line @typescript-eslint/no-unnecessary-condition
if (error || !sprawnosc) return Astro.redirect("/sprawnosci");

const { data: allSprawnosci } = (await supabase.from("sprawnosci").select("kategoria").order("kategoria")) as {
  data: Pick<Sprawnosc, "kategoria">[] | null;
};

const kategorie = [...new Set((allSprawnosci ?? []).map((s) => s.kategoria).filter(Boolean) as string[])].sort();
---

<AppLayout title={`Edytuj: ${sprawnosc.nazwa}`}>
  <div class="mb-6">
    <a href="/sprawnosci" class="mb-1 inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700">
      ← Powrót do słownika
    </a>
    <h1 class="text-2xl font-bold text-gray-900">Edytuj sprawność</h1>
  </div>

  <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <SprawnosccForm sprawnosc={sprawnosc} existingKategorie={kategorie} redirectTo="/sprawnosci" client:load />
  </div>
</AppLayout>
