---
import AppLayout from "@/layouts/AppLayout.astro";
import { createClient } from "@/lib/supabase";
import type { Zbiorka } from "@/types";

const supabase = createClient(Astro.request.headers, Astro.cookies);

const q = Astro.url.searchParams.get("q")?.trim() ?? "";
const od = Astro.url.searchParams.get("od") ?? "";
const do_ = Astro.url.searchParams.get("do") ?? "";

let query = supabase ? supabase.from("zbiorki").select("*") : null;

if (query) {
  if (q) {
    query = query.or(`temat.ilike.%${q}%,miejsce.ilike.%${q}%`);
  }
  if (od) {
    query = query.gte("data", od);
  }
  if (do_) {
    query = query.lte("data", do_);
  }
  query = query.order("data", { ascending: false });
}

const { data: zbiorki } = query ? await query : { data: [] as Zbiorka[] };

const filtrowane = !!(q || od || do_);

function formatDate(iso: string | null) {
  if (!iso) return "—";
  const [y, m, d] = iso.split("-");
  return `${d}.${m}.${y}`;
}
---

<AppLayout title="Zbiórki">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Zbiórki</h1>
    <a
      href="/zbiorki/nowa"
      class="rounded-md bg-green-700 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-green-800"
    >
      + Dodaj zbiórkę
    </a>
  </div>

  <!-- Filtry -->
  <form method="GET" action="/zbiorki" class="mb-4 flex flex-wrap items-end gap-3">
    <div class="min-w-48 flex-1">
      <label for="q" class="mb-1 block text-xs font-medium text-gray-500">Szukaj</label>
      <input
        id="q"
        name="q"
        type="text"
        value={q}
        placeholder="Temat lub miejsce…"
        class="w-full rounded-md border border-gray-300 px-3 py-1.5 text-sm focus:border-green-500 focus:ring-2 focus:ring-green-300 focus:outline-none"
      />
    </div>
    <div>
      <label for="od" class="mb-1 block text-xs font-medium text-gray-500">Od</label>
      <input
        id="od"
        name="od"
        type="date"
        value={od}
        class="rounded-md border border-gray-300 px-3 py-1.5 text-sm focus:border-green-500 focus:ring-2 focus:ring-green-300 focus:outline-none"
      />
    </div>
    <div>
      <label for="do" class="mb-1 block text-xs font-medium text-gray-500">Do</label>
      <input
        id="do"
        name="do"
        type="date"
        value={do_}
        class="rounded-md border border-gray-300 px-3 py-1.5 text-sm focus:border-green-500 focus:ring-2 focus:ring-green-300 focus:outline-none"
      />
    </div>
    <button
      type="submit"
      class="rounded-md bg-green-700 px-4 py-1.5 text-sm font-medium text-white transition-colors hover:bg-green-800"
    >
      Filtruj
    </button>
    {
      filtrowane && (
        <a href="/zbiorki" class="text-sm text-gray-500 hover:text-gray-700 hover:underline">
          Wyczyść
        </a>
      )
    }
  </form>

  {
    zbiorki && zbiorki.length > 0 ? (
      <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-left text-xs font-semibold tracking-wide text-gray-500 uppercase">
            <tr>
              <th class="px-4 py-3">Data</th>
              <th class="px-4 py-3">Temat</th>
              <th class="px-4 py-3">Miejsce</th>
              <th class="px-4 py-3" />
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {zbiorki.map((z: Zbiorka) => (
              <tr class="transition-colors hover:bg-gray-50">
                <td class="px-4 py-3 font-medium text-gray-900">{formatDate(z.data)}</td>
                <td class="px-4 py-3 text-gray-600">{z.temat ?? "—"}</td>
                <td class="px-4 py-3 text-gray-600">{z.miejsce ?? "—"}</td>
                <td class="px-4 py-3 text-right">
                  <a href={`/zbiorki/${z.id}/obecnosci`} class="mr-3 text-green-700 hover:underline">
                    Obecności
                  </a>
                  <a href={`/zbiorki/${z.id}/edytuj`} class="mr-3 text-blue-600 hover:underline">
                    Edytuj
                  </a>
                  <button
                    class="text-red-500 hover:underline"
                    data-delete-id={z.id}
                    data-delete-name={formatDate(z.data)}
                  >
                    Usuń
                  </button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="rounded-lg border border-dashed border-gray-300 bg-white p-12 text-center text-gray-500">
        {filtrowane ? (
          <p class="text-lg">Brak zbiórek pasujących do filtrów.</p>
        ) : (
          <>
            <p class="text-lg">Brak zbiórek w bazie.</p>
            <a href="/zbiorki/nowa" class="mt-3 inline-block text-green-700 hover:underline">
              Dodaj pierwszą zbiórkę →
            </a>
          </>
        )}
      </div>
    )
  }
</AppLayout>

<script>
  document.querySelectorAll("[data-delete-id]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const id = (btn as HTMLElement).dataset.deleteId!;
      const name = (btn as HTMLElement).dataset.deleteName!;
      if (!confirm(`Usuń zbiórkę z dnia ${name}? Usunięte zostaną też wszystkie wpisy obecności.`)) return;

      const res = await fetch(`/api/zbiorki/${id}`, { method: "DELETE" });
      if (res.ok) {
        window.location.reload();
      } else {
        alert("Błąd podczas usuwania. Spróbuj ponownie.");
      }
    });
  });
</script>
