---
import AppLayout from "@/layouts/AppLayout.astro";
import ObecnosciForm from "@/components/zbiorki/ObecnosciForm";
import { createClient } from "@/lib/supabase";
import type { Zbiorka, Wilczek, Obecnosc } from "@/types";

const { id } = Astro.params;

const supabase = createClient(Astro.request.headers, Astro.cookies);
if (!supabase) return Astro.redirect("/zbiorki");

const [{ data: zbiorka, error: ze }, { data: wilczki }, { data: obecnosci }] = await Promise.all([
  supabase.from("zbiorki").select("*").eq("id", id).single<Zbiorka>(),
  supabase.from("wilczki").select("*").order("nazwisko").order("imie"),
  supabase.from("obecnosci").select("*").eq("zbiorka_id", id),
]);

// eslint-disable-next-line @typescript-eslint/no-unnecessary-condition
if (ze || !zbiorka) return Astro.redirect("/zbiorki");

const initialObeznoscis: Record<string, boolean> = Object.fromEntries(
  ((obecnosci as Obecnosc[] | null) ?? []).map((o) => [o.wilczek_id, o.obecny]),
);

function formatDate(iso: string) {
  const [y, m, d] = iso.split("-");
  return `${d}.${m}.${y}`;
}
---

<AppLayout title={`Obecności — ${formatDate(zbiorka.data)}`}>
  <div class="mb-6 flex items-start justify-between">
    <div>
      <a href="/zbiorki" class="mb-1 inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700">
        ← Powrót do listy
      </a>
      <h1 class="text-2xl font-bold text-gray-900">Obecności — {formatDate(zbiorka.data)}</h1>
      {
        (zbiorka.temat != null || zbiorka.miejsce != null) && (
          <p class="mt-1 text-sm text-gray-500">
            {zbiorka.temat}
            {zbiorka.temat != null && zbiorka.miejsce != null ? " · " : ""}
            {zbiorka.miejsce}
          </p>
        )
      }
    </div>
    <a
      href={`/zbiorki/${zbiorka.id}/edytuj`}
      class="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-50"
    >
      Edytuj zbiórkę
    </a>
  </div>

  <div class="max-w-2xl">
    <ObecnosciForm
      zbiorkaId={zbiorka.id}
      wilczki={(wilczki as Wilczek[] | null) ?? []}
      initialObeznoscis={initialObeznoscis}
      client:load
    />
  </div>
</AppLayout>
