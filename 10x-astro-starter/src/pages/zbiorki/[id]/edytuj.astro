---
import AppLayout from "@/layouts/AppLayout.astro";
import ZbiorkaForm from "@/components/zbiorki/ZbiorkaForm";
import { createClient } from "@/lib/supabase";
import type { Zbiorka } from "@/types";

const { id } = Astro.params;

const supabase = createClient(Astro.request.headers, Astro.cookies);
if (!supabase) return Astro.redirect("/zbiorki");

const { data: zbiorka, error } = await supabase.from("zbiorki").select("*").eq("id", id).single<Zbiorka>();

// eslint-disable-next-line @typescript-eslint/no-unnecessary-condition
if (error || !zbiorka) return Astro.redirect("/zbiorki");

function formatDate(iso: string) {
  const [y, m, d] = iso.split("-");
  return `${d}.${m}.${y}`;
}
---

<AppLayout title={`Edytuj zbiórkę — ${formatDate(zbiorka.data)}`}>
  <div class="mb-6 flex items-start justify-between">
    <div>
      <a href="/zbiorki" class="mb-1 inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700">
        ← Powrót do listy
      </a>
      <h1 class="text-2xl font-bold text-gray-900">Edytuj zbiórkę — {formatDate(zbiorka.data)}</h1>
    </div>
    <a
      href={`/zbiorki/${zbiorka.id}/obecnosci`}
      class="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-50"
    >
      Obecności →
    </a>
  </div>

  <div class="max-w-2xl rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <ZbiorkaForm zbiorka={zbiorka} client:load />
  </div>
</AppLayout>
