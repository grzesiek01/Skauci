---
import AppLayout from "@/layouts/AppLayout.astro";
import WilczekForm from "@/components/wilczki/WilczekForm";
---

<AppLayout title="Nowy wilczek">
  <div class="mb-6">
    <a href="/wilczki" class="mb-1 inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700">
      ← Powrót do listy
    </a>
    <h1 class="text-2xl font-bold text-gray-900">Nowy wilczek</h1>
  </div>

  <div class="max-w-2xl rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <WilczekForm client:load />
  </div>
</AppLayout>
