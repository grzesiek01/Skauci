---
import AppLayout from "@/layouts/AppLayout.astro";
import FunkcjaForm from "@/components/wilczki/FunkcjaForm";
import { createClient } from "@/lib/supabase";
import type { Wilczek } from "@/types";

const { id } = Astro.params;
const supabase = createClient(Astro.request.headers, Astro.cookies);
if (!supabase) return Astro.redirect("/auth/signin");

const { data: wilczek, error } = await supabase.from("wilczki").select("*").eq("id", id).single<Wilczek>();

// eslint-disable-next-line @typescript-eslint/no-unnecessary-condition
if (error || !wilczek) return Astro.redirect("/wilczki");
---

<AppLayout title={`Dodaj funkcję — ${wilczek.imie} ${wilczek.nazwisko}`}>
  <div class="mb-6">
    <a
      href={`/wilczki/${id}?tab=funkcje`}
      class="mb-1 inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700"
    >
      ← Powrót do profilu
    </a>
    <h1 class="text-2xl font-bold text-gray-900">Dodaj funkcję</h1>
    <p class="mt-1 text-sm text-gray-500">{wilczek.imie} {wilczek.nazwisko}</p>
  </div>

  <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <FunkcjaForm wilczekId={id} client:load />
  </div>
</AppLayout>
