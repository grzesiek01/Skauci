---
import AppLayout from "@/layouts/AppLayout.astro";
import WilczekForm from "@/components/wilczki/WilczekForm";
import { createClient } from "@/lib/supabase";
import type { Wilczek } from "@/types";

const { id } = Astro.params;

const supabase = createClient(Astro.request.headers, Astro.cookies);
if (!supabase) return Astro.redirect("/wilczki");

const { data: wilczek, error } = await supabase.from("wilczki").select("*").eq("id", id).single<Wilczek>();

// eslint-disable-next-line @typescript-eslint/no-unnecessary-condition
if (error || !wilczek) return Astro.redirect("/wilczki");
---

<AppLayout title={`Edytuj — ${wilczek.imie} ${wilczek.nazwisko}`}>
  <div class="mb-6 flex items-start justify-between">
    <div>
      <div class="mb-1 flex items-center gap-3 text-sm text-gray-500">
        <a href="/wilczki" class="hover:text-gray-700">← Lista</a>
        <span>/</span>
        <a href={`/wilczki/${wilczek.id}`} class="hover:text-gray-700">{wilczek.imie} {wilczek.nazwisko}</a>
      </div>
      <h1 class="text-2xl font-bold text-gray-900">Edytuj: {wilczek.imie} {wilczek.nazwisko}</h1>
    </div>
    <a
      href={`/wilczki/${wilczek.id}`}
      class="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-50"
    >
      Profil wilczka →
    </a>
  </div>

  <div class="max-w-2xl rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <WilczekForm wilczek={wilczek} client:load />
  </div>
</AppLayout>
