---
import AppLayout from "@/layouts/AppLayout.astro";
import RodzicForm from "@/components/wilczki/RodzicForm";
import { createClient } from "@/lib/supabase";
import type { Wilczek, Rodzic } from "@/types";

const { id, rodzic_id } = Astro.params;

const supabase = createClient(Astro.request.headers, Astro.cookies);
if (!supabase) return Astro.redirect("/wilczki");

const [{ data: wilczek, error: we }, { data: rodzic, error: re }, { data: wszyscyRodzice }] = await Promise.all([
  supabase.from("wilczki").select("*").eq("id", id).single<Wilczek>(),
  supabase.from("rodzice").select("*").eq("id", rodzic_id).single<Rodzic>(),
  supabase.from("rodzice").select("*").eq("wilczek_id", id),
]);

// eslint-disable-next-line @typescript-eslint/no-unnecessary-condition
if (we || !wilczek || re || !rodzic) return Astro.redirect(`/wilczki/${id}?tab=dane`);
---

<AppLayout title={`Edytuj rodzica — ${wilczek.imie} ${wilczek.nazwisko}`}>
  <div class="mb-6">
    <a
      href={`/wilczki/${wilczek.id}?tab=dane`}
      class="mb-1 inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700"
    >
      ← Powrót do profilu
    </a>
    <h1 class="text-2xl font-bold text-gray-900">
      Edytuj rodzica — {wilczek.imie}
      {wilczek.nazwisko}
    </h1>
  </div>

  <div class="max-w-2xl rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <RodzicForm
      wilczekId={wilczek.id}
      rodzic={rodzic}
      existingRodzice={(wszyscyRodzice as Rodzic[] | null) ?? []}
      client:load
    />
  </div>
</AppLayout>
