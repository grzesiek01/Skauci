---
import AppLayout from "@/layouts/AppLayout.astro";
import RodzicForm from "@/components/wilczki/RodzicForm";
import { createClient } from "@/lib/supabase";
import type { Wilczek, Rodzic } from "@/types";

const { id } = Astro.params;

const supabase = createClient(Astro.request.headers, Astro.cookies);
if (!supabase) return Astro.redirect("/wilczki");

const { data: wilczek, error: we } = await supabase.from("wilczki").select("*").eq("id", id).single<Wilczek>();

// eslint-disable-next-line @typescript-eslint/no-unnecessary-condition
if (we || !wilczek) return Astro.redirect("/wilczki");

const { data: rodzice } = (await supabase.from("rodzice").select("*").eq("wilczek_id", id)) as {
  data: Rodzic[] | null;
};

if (rodzice && rodzice.length >= 2) return Astro.redirect(`/wilczki/${id}?tab=dane`);
---

<AppLayout title={`Dodaj rodzica — ${wilczek.imie} ${wilczek.nazwisko}`}>
  <div class="mb-6">
    <a
      href={`/wilczki/${wilczek.id}?tab=dane`}
      class="mb-1 inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700"
    >
      ← Powrót do profilu
    </a>
    <h1 class="text-2xl font-bold text-gray-900">
      Dodaj rodzica — {wilczek.imie}
      {wilczek.nazwisko}
    </h1>
  </div>

  <div class="max-w-2xl rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <RodzicForm wilczekId={wilczek.id} existingRodzice={rodzice ?? []} client:load />
  </div>
</AppLayout>
