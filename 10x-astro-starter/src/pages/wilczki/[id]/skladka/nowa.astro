---
import AppLayout from "@/layouts/AppLayout.astro";
import SkladkaForm from "@/components/wilczki/SkladkaForm";
import { createClient } from "@/lib/supabase";
import type { Wilczek, Skladka } from "@/types";

const { id } = Astro.params;

const supabase = createClient(Astro.request.headers, Astro.cookies);
if (!supabase) return Astro.redirect("/wilczki");

const { data: wilczek, error: we } = await supabase.from("wilczki").select("*").eq("id", id).single<Wilczek>();

// eslint-disable-next-line @typescript-eslint/no-unnecessary-condition
if (we || !wilczek) return Astro.redirect("/wilczki");

const { data: skladki } = (await supabase.from("skladki").select("rok").eq("wilczek_id", id)) as {
  data: Pick<Skladka, "rok">[] | null;
};

const existingLata = (skladki ?? []).map((s) => s.rok);
---

<AppLayout title={`Dodaj składkę — ${wilczek.imie} ${wilczek.nazwisko}`}>
  <div class="mb-6">
    <a
      href={`/wilczki/${wilczek.id}?tab=skladki`}
      class="mb-1 inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700"
    >
      ← Powrót do profilu
    </a>
    <h1 class="text-2xl font-bold text-gray-900">
      Dodaj składkę — {wilczek.imie}
      {wilczek.nazwisko}
    </h1>
  </div>

  <div class="max-w-2xl rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <SkladkaForm wilczekId={wilczek.id} existingLata={existingLata} client:load />
  </div>
</AppLayout>
