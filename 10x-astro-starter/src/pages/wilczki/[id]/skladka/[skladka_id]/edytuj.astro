---
import AppLayout from "@/layouts/AppLayout.astro";
import SkladkaForm from "@/components/wilczki/SkladkaForm";
import { createClient } from "@/lib/supabase";
import type { Wilczek, Skladka } from "@/types";

const { id, skladka_id } = Astro.params;

const supabase = createClient(Astro.request.headers, Astro.cookies);
if (!supabase) return Astro.redirect("/wilczki");

const [{ data: wilczek, error: we }, { data: skladka, error: se }] = await Promise.all([
  supabase.from("wilczki").select("*").eq("id", id).single<Wilczek>(),
  supabase.from("skladki").select("*").eq("id", skladka_id).single<Skladka>(),
]);

// eslint-disable-next-line @typescript-eslint/no-unnecessary-condition
if (we || !wilczek || se || !skladka) return Astro.redirect(`/wilczki/${id}?tab=skladki`);
---

<AppLayout title={`Edytuj składkę ${skladka.rok} — ${wilczek.imie} ${wilczek.nazwisko}`}>
  <div class="mb-6">
    <a
      href={`/wilczki/${wilczek.id}?tab=skladki`}
      class="mb-1 inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700"
    >
      ← Powrót do profilu
    </a>
    <h1 class="text-2xl font-bold text-gray-900">
      Składka {skladka.rok} — {wilczek.imie}
      {wilczek.nazwisko}
    </h1>
  </div>

  <div class="max-w-2xl rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
    <SkladkaForm wilczekId={wilczek.id} skladka={skladka} existingLata={[]} client:load />
  </div>
</AppLayout>
